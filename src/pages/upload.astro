---
import Footer from "@/components/layout/Footer.tsx"
import Header from "@/components/layout/Header.tsx"
import VideoUploader from "@/components/upload/VideoUploader.tsx"
import Layout from "@/layouts/Layout.astro"
---

<Layout title="SKY DUMP - Upload Files">
  <div class="min-h-screen bg-gradient-to-br from-blue-950 via-indigo-950 to-purple-950 flex flex-col">
    <Header client:load showBack />
    <main class="flex-1 flex flex-col items-center px-4 py-12">
      <div class="text-center mb-8">
        <h1 class="text-4xl md:text-5xl font-black mb-3 tracking-tight">
          <span class="text-primary">SKY</span>
          <span class="text-foreground"> DUMP</span>
        </h1>
        <p class="text-lg text-muted-foreground">
          Drop your video files below to upload
        </p>
      </div>
      <div class="w-full max-w-3xl">
        <VideoUploader client:load />
      </div>
    </main>
    <Footer client:load />
  </div>
</Layout>
